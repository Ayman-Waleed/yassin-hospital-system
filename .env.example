# انسخ هذا الملف باسم .env وعدّل القيم حسب جهازك
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=nasser_hospital
PORT=5000

# سر توقيع جلسات الدخول — غيّره لقيمة عشوائية طويلة على الاستضافة
SESSION_SECRET=change-me-to-a-long-random-string

# اتصال مشفر بقاعدة البيانات (true للقواعد السحابية مثل TiDB/Aiven، false محلياً)
DB_SSL=false

# على الاستضافة اضبطها production حتى تصبح كوكيز الجلسة آمنة (HTTPS فقط)
# NODE_ENV=production
